# Shared
STAFF_API_KEY=dev-staff-key

# MySQL root
MYSQL_ROOT_PASSWORD=root_password

# MySQL for user_service
USER_MYSQL_DATABASE=user_db
USER_MYSQL_USER=user_user
USER_MYSQL_PASSWORD=user_password

# MySQL for order_service
ORDER_MYSQL_DATABASE=order_db
ORDER_MYSQL_USER=order_user
ORDER_MYSQL_PASSWORD=order_password

# PostgreSQL shared by product_service and chatbot_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PRODUCT_POSTGRES_DB=product_db
CHATBOT_POSTGRES_DB=chatbot_db

# Internal service URLs inside the Docker network
USER_SERVICE_URL=http://user-service:8000
PRODUCT_SERVICE_URL=http://product-service:8000
ORDER_SERVICE_URL=http://order-service:8000
CHATBOT_SERVICE_URL=http://chatbot-service:8000
ORDER_SERVICE_INTERNAL_KEY=dev-order-internal-key

# Host ports for smoke tests and local inspection
# user_service: 8000 and 8003
# product_service: 8001
# chatbot_service: 8005

# user_service -> chatbot request behavior
CHATBOT_REQUEST_TIMEOUT_SECONDS=40
CHATBOT_REQUEST_RETRIES=2
CHATBOT_INGEST_KEY=

# Chatbot artifacts persist on host via bind mount: services/chatbot_service/chatbot/artifacts

# Chatbot LLM provider
LLM_PROVIDER=gemma
GEMMA_MODEL=gemma-4-31b-it
GEMMA_TIMEOUT_SECONDS=45

# Google AI Studio key used by Gemma/Gemini providers
GEMINI_API_KEY=
CHATBOT_GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SECONDS=35

# OpenRouter optional settings
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=kiemtra01-chatbot
