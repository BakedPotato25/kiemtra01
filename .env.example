# Shared
STAFF_API_KEY=dev-staff-key

# MySQL root
MYSQL_ROOT_PASSWORD=root_password

# MySQL for customer service
CUSTOMER_MYSQL_DATABASE=customer_db
CUSTOMER_MYSQL_USER=customer_user
CUSTOMER_MYSQL_PASSWORD=customer_password

# MySQL for staff service
STAFF_MYSQL_DATABASE=staff_db
STAFF_MYSQL_USER=staff_user
STAFF_MYSQL_PASSWORD=staff_password

# PostgreSQL for catalog services
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Internal service URLs inside Docker network
LAPTOP_SERVICE_URL=http://laptop-service:8000
MOBILE_SERVICE_URL=http://mobile-service:8000
ACCESSORY_SERVICE_URL=http://accessory-service:8000
CHATBOT_SERVICE_URL=http://chatbot-service:8000
CUSTOMER_SERVICE_URL=http://customer-service:8000
STAFF_SERVICE_URL=http://staff-service:8000

# Customer -> chatbot request behavior
CHATBOT_REQUEST_TIMEOUT_SECONDS=40
CHATBOT_REQUEST_RETRIES=2
CHATBOT_INGEST_KEY=

# Chatbot LLM provider
LLM_PROVIDER=gemma
GEMMA_MODEL=gemma-4-31b-it
GEMMA_TIMEOUT_SECONDS=45

# Google AI Studio key used by Gemma/Gemini providers
GEMINI_API_KEY=

# Docker Compose maps this host env into chatbot_service as GEMINI_MODEL
CHATBOT_GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SECONDS=35

# OpenRouter optional settings
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=kiemtra01-chatbot
