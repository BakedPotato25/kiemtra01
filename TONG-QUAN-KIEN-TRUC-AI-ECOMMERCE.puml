@startuml
!theme plain
left to right direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName Arial

actor "Khach hang" as User
actor "Nhan vien" as Staff

rectangle "Frontend (Web UI)" as FE

package "E-commerce Microservices" {
  component "customer_service\nDjango" as Customer
  component "staff_service\nDjango" as StaffSvc
  component "chatbot_service\nDjango" as Chatbot
  component "laptop_service\nDjango" as Laptop
  component "mobile_service\nDjango" as Mobile
  component "accessory_service\nDjango" as Accessory
}

package "AI Layer" {
  component "Behavior Event Ingestion" as BehaviorIngest
  component "Feature Builder\n(12 features)" as FeatureBuilder
  component "Deep Learning Model\nmodel_behavior.json" as BehaviorModel
  component "Knowledge Base Builder\nknowledge_base.json" as KbBuilder
  component "RAG Retriever\nTop-K + Citations" as RagRetriever
  component "LLM Gateway\n(Gemma/Gemini + Fallback)" as LlmGateway
}

package "Data Layer" {
  database "MySQL\n(customer_db, staff_db)" as Mysql
  database "PostgreSQL\n(laptop/mobile/accessory db)" as Pg
  database "SQLite\n(chatbot events + artifacts)" as Sqlite
}

package "Ops / MLOps" {
  component "backfill_chatbot_behavior\n(command)" as BackfillCmd
  component "train_behavior_model\n(command)" as TrainCmd
  component "build_chat_kb\n(command)" as BuildKbCmd
  component "Docker Compose" as Compose
}

cloud "External LLM Provider" as LLM

User --> FE : chat, tim kiem, dat hang
Staff --> FE : quan tri, quan ly san pham

FE --> Customer : HTTP
FE --> StaffSvc : HTTP
Customer --> Chatbot : /customer/chatbot/reply

Customer --> Mysql : order, cart, saved
StaffSvc --> Mysql : staff ops
Laptop --> Pg : catalog laptop
Mobile --> Pg : catalog mobile
Accessory --> Pg : catalog accessory

Chatbot --> BehaviorIngest : ghi su kien hanh vi
BehaviorIngest --> Sqlite : BehaviorEvent

Chatbot --> FeatureBuilder : tao feature theo user_ref
FeatureBuilder --> BehaviorModel : infer intent/category
BehaviorModel --> Sqlite : doc model artifact

Chatbot --> RagRetriever : truy van RAG context
RagRetriever --> KbBuilder : doc KB artifact
KbBuilder --> Sqlite : doc knowledge base

RagRetriever --> Laptop : lay san pham lien quan
RagRetriever --> Mobile : lay san pham lien quan
RagRetriever --> Accessory : lay san pham lien quan

Chatbot --> LlmGateway : prompt + context + recs
LlmGateway --> LLM : call API
LlmGateway --> Chatbot : answer or fallback

BackfillCmd --> Customer : doc du lieu lich su
BackfillCmd --> Chatbot : ingest-behavior endpoint
TrainCmd --> BehaviorModel : train + save model
TrainCmd --> Sqlite : update model_behavior.json
BuildKbCmd --> KbBuilder : build knowledge base
BuildKbCmd --> Laptop : fetch products
BuildKbCmd --> Mobile : fetch products
BuildKbCmd --> Accessory : fetch products
BuildKbCmd --> Sqlite : update knowledge_base.json

Compose ..> Customer : run
Compose ..> StaffSvc : run
Compose ..> Chatbot : run
Compose ..> Laptop : run
Compose ..> Mobile : run
Compose ..> Accessory : run
Compose ..> Mysql : run
Compose ..> Pg : run

note right of Chatbot
  Chatbot response =
  behavior signal + RAG docs +
  recommendation candidates + LLM/fallback
end note

@enduml
